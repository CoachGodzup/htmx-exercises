{
  "name": "htmx-exercises",
  "version": "1.0.0",
  "scripts": {
    "dev": "node server.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint . && stylelint '**/*.css'",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs}": "eslint --fix",
